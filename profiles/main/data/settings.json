{
  "[dart]": {
    "editor.formatOnSave": true,
    "editor.formatOnType": true,
    "editor.rulers": [
      80
    ],
    "editor.selectionHighlight": false,
    "editor.suggest.snippetsPreventQuickSuggestions": false,
    "editor.suggestSelection": "first",
    "editor.tabCompletion": "onlySnippets",
    "editor.wordBasedSuggestions": "off"
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features",
    "editor.formatOnPaste": true
  },
  "[jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features",
    "editor.formatOnPaste": true
  },
  "[python]": {
    "editor.defaultFormatter": "ms-python.autopep8",
    "editor.formatOnSave": true,
    "editor.formatOnType": true
  },
  "[typescript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features",
    "editor.formatOnPaste": true,
    "editor.formatOnSave": true
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnPaste": true,
    "editor.formatOnSave": true
  },
  "dart.debugExternalLibraries": false,
  "dart.debugSdkLibraries": false,
  "dart.flutterHotReloadOnSave": "always",
  "debug.toolBarLocation": "commandCenter",
  "diffEditor.ignoreTrimWhitespace": false,
  "diffEditor.renderSideBySide": false,
  "dotfiles.repository": "offlinehacker/dotfiles",
  "editor.fontFamily": "'Source Code Pro', monospace",
  "editor.guides.bracketPairs": true,
  "editor.guides.highlightActiveIndentation": true,
  "editor.inlineSuggest.enabled": true,
  "editor.largeFileOptimizations": false,
  "editor.stickyScroll.enabled": true,
  "editor.stickyScroll.maxLineCount": 2,
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "extensions.ignoreRecommendations": true,
  "files.associations": {
    "*.sql": "sql",
    "*.cu": "cuda-cpp"
  },
  "files.exclude": {
    "**/.DS_Store": true,
    "**/.git": true,
    "**/.hg": true,
    "**/.pnpm-debug.log": true,
    "**/.pnpm-store": true,
    "**/.svn": true,
    "**/CVS": true,
    "**/node_modules": true,
    "**/Thumbs.db": true
  },
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": false,
  "github.copilot.enable": {
    "*": true,
    "plaintext": false,
    "markdown": false,
    "scminput": false,
    "go": true,
    "yaml": true
  },
  "github.remoteName": "main",
  "githubPullRequests.pushBranch": "always",
  "gitlens.codeLens.enabled": false,
  "gitlens.currentLine.enabled": false,
  "gitlens.defaultDateStyle": "absolute",
  "gitlens.hovers.currentLine.over": "line",
  "go.useLanguageServer": true,
  "go.toolsManagement.autoUpdate": true,
  "gopls": {
    "ui.navigation.importShortcut": "Definition"
  },
  "javascript.updateImportsOnFileMove.enabled": "always",
  "macros": {
    "quickOpenWithWordUnderCursor": [
      {
        "javascript": [
          "const editor = vscode.window.activeTextEditor;",
          "const position = editor.selection.active;",
          "const lineText = editor.document.lineAt(position.line).text;",
          "const match = /(\\S+)@(\\S+)/.exec(lineText)",
          "vscode.commands.executeCommand('workbench.action.quickOpen', `#${match[2]} ${match[1]}`);"
        ]
      }
    ]
  },
  "markdown.editor.pasteUrlAsFormattedLink.enabled": "smart",
  "notebook.cellToolbarLocation": {
    "default": "right",
    "jupyter-notebook": "left"
  },
  "notebook.lineNumbers": "on",
  "notebook.markup.fontSize": 14,
  "notebook.output.scrolling": true,
  "python.formatting.provider": "black",
  "python.linting.enabled": true,
  "python.linting.mypyEnabled": true,
  "python.linting.pylintEnabled": false,
  "python.testing.autoTestDiscoverOnSaveEnabled": true,
  "redhat.telemetry.enabled": false,
  "rewrap.autoWrap.enabled": true,
  "remote.SSH.defaultExtensions": [
    "EditorConfig.EditorConfig",
    "redhat.vscode-yaml",
    "reduckted.vscode-gitweblinks"
  ],
  "remote.SSH.useExecServer": false,
  "dev.containers.defaultExtensions": [
    "EditorConfig.EditorConfig",
    "redhat.vscode-yaml",
    "reduckted.vscode-gitweblinks"
  ],
  "terminal.integrated.commandsToSkipShell": [
    "workbench.action.toggleSidebarVisibility",
    "workbench.action.openEditorAtIndex1",
    "workbench.action.openEditorAtIndex2",
    "workbench.action.openEditorAtIndex3",
    "workbench.action.openEditorAtIndex4",
    "workbench.action.openEditorAtIndex5",
    "workbench.action.moveEditorToPreviousGroup",
    "workbench.action.moveEditorToNextGroup",
    "workbench.action.pinEditor",
    "workbench.action.unpinEditor",
    "workbench.action.terminal.rename"
  ],
  "terminal.integrated.allowChords": true,
  "terminal.integrated.sendKeybindingsToShell": false,
  "terminal.integrated.defaultProfile.linux": "bash",
  "terminal.integrated.fontFamily": "Consolas, monospace",
  "terminal.integrated.fontSize": 15,
  "terminal.integrated.fontWeight": "normal",
  "terminal.integrated.scrollback": 5000,
  "terminal.integrated.tabs.enableAnimation": false,
  "terminal.integrated.tabs.enabled": true,
  "terminal.integrated.showExitAlert": false,
  "terminal.integrated.suggest.enabled": false,
  "terminal.integrated.gpuAcceleration": "on",
  "typescript.updateImportsOnFileMove.enabled": "always",
  "update.mode": "none",
  "window.confirmBeforeClose": "always",
  "window.menuBarVisibility": "hidden",
  "window.restoreWindows": "none",
  "window.titleBarStyle": "custom",
  "workbench.editorAssociations": {
    "*.ipynb": "jupyter.notebook.ipynb"
  },
  "workbench.iconTheme": "vscode-great-icons",
  "window.autoDetectColorScheme": true,
  "window.autoDetectHighContrast": true,
  "workbench.preferredDarkColorTheme": "Catppuccin Mocha",
  "workbench.preferredLightColorTheme": "Adwaita Light",
  "workbench.startupEditor": "none",
  "workbench.panel.defaultLocation": "right",
  "zenMode.fullScreen": true,
  "zenMode.hideLineNumbers": false,
  "zenMode.hideStatusBar": true,
  "zenMode.hideActivityBar": true,
  "zenMode.centerLayout": true,
  "zenMode.showTabs": "none",
  "snyk.yesWelcomeNotification": false,
  "editor.codeActionWidget.includeNearbyQuickFixes": true,
  "workbench.activityBar.location": "top",
  "editor.occurrencesHighlight": "multiFile",
  "workbench.tree.enableStickyScroll": true,
  "multiDiffEditor.experimental.enabled": true,
  "diffEditor.codeLens": true,
  "cmake.allowUnsupportedPresetsVersions": true,
  "cmake.configureOnOpen": false,
  "cmake.showOptionsMovedNotification": false,
  "jupyter.debugJustMyCode": false,
	"C_Cpp.files.exclude": {
    "**/.vscode": true,
    "**/.vs": true,
    "/": true
  },
  "extensions.experimental.deferredStartupFinishedActivation": true,
  "workbench.editor.pinnedTabsOnSeparateRow": true,
  "workbench.editor.preventPinnedEditorClose": "never",
  "cmake.pinnedCommands": [
    "workbench.action.tasks.configureTaskRunner",
    "workbench.action.tasks.runTask"
  ],
  "cmake.environment": {
    "CC": "/usr/bin/clang",
    "CXX": "/usr/bin/clang++"
  },
  "remote.SSH.remotePlatform": {
    "1": "linux",
    "2": "linux",
    "3": "linux",
    "4": "linux",
    "ubuntu-dev": "linux",
    "ubuntu-dev-new": "linux",
    "ai-experiments": "linux"
  },
  "window.customTitleBarVisibility": "auto",
  "workbench.colorTheme": "Catppuccin Mocha",
}
